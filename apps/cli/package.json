{
  "name": "@emdzej/ibusx-cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "ibusx": "./dist/bin/ibusx.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "start": "node dist/bin/ibusx.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@emdzej/ibusx-commands": "workspace:*",
    "@emdzej/ibusx-core": "workspace:*",
    "@emdzej/ibusx-devices": "workspace:*",
    "@emdzej/ibusx-protocol": "workspace:*",
    "@emdzej/ibusx-transport-serial": "workspace:*",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@emdzej/ibusx-tsconfig": "workspace:*",
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
